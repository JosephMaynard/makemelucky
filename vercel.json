{
	"headers": [
		{
			"source": "/v1/(.*)",
			"headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
		},
		{
			"source": "/v2/(.*)",
			"headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
		},
		{
			"source": "/assets/(.*)",
			"headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
		},
		{
			"source": "/fonts/(.*)",
			"headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
		},
		{
			"source": "/soundfx/(.*)",
			"headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
		}
	]
}
